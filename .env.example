# Seed database and integration test inputs
S3_BUCKET=
S3_ACCESS_KEY_ID=
S3_SECRET_ACCESS_KEY=
S3_REGION=auto
S3_SEED_DATABASE_OBJECT_KEY=ff_feed_indexer_seed.sqlite

