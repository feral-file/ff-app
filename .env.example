# Required for app startup
INDEXER_API_URL=
INDEXER_API_KEY=
FF1_RELAYER_URL=
FF1_RELAYER_API_KEY=

# Optional runtime integrations
DP1_FEED_URL=
DP1_FEED_API_KEY=
DOMAIN_RESOLVER_URL=
DOMAIN_RESOLVER_API_KEY=
REMOTE_CONFIG_URL=
RELEASE_NOTES_MARKDOWN_URL=
PUBDOC_URL=
# Override the default public feral-file/docs base used for legal documents.
FERALFILE_DOCS_URL=
SUPPORT_API_KEY=
SENTRY_DSN=
ASSET_URL=
